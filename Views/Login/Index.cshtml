@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta name="viewport" content="width=device-width" />
    <title>Login - Sale Management</title>
    <link href="~/Content/bootstrap.min.css" rel="stylesheet" />
</head>
<body style="background-color: #f4f6f9; display: flex; justify-content: center; align-items: center; height: 100vh;">

    <div class="card" style="width: 400px; padding: 20px; box-shadow: 0 4px 8px rgba(0,0,0,0.1);">
        <h3 class="text-center">SYSTEM LOGIN</h3>
        <hr />

        @if (ViewBag.Error != null)
        {
            <div class="alert alert-danger">@ViewBag.Error</div>
        }

        <form action="/Login/Index" method="post">
            <div class="form-group">
                <label>Email</label>
                <input type="email" name="email" class="form-control" required />
            </div>
            <br />
            <div class="form-group">
                <label>Password</label>
                <input type="password" name="password" class="form-control" required />
            </div>
            <br />
            <button type="submit" class="btn btn-primary btn-block" style="width: 100%;">Login</button>
        </form>
    </div>

</body>
</html>