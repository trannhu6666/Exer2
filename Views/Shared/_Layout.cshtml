<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewBag.Title - Hệ Thống Bán Hàng</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />

    <style>
        /* CSS hiệu ứng giống hệt bên Core */
        .nav-link {
            font-weight: 500;
            transition: all 0.3s ease;
        }

            .nav-link:hover {
                color: #f8f9fa !important;
                transform: translateY(-2px);
            }

        .btn-order {
            border-radius: 20px;
            box-shadow: 0 4px 6px rgba(40, 167, 69, 0.3);
        }

            .btn-order:hover {
                background-color: #218838;
                box-shadow: 0 6px 8px rgba(40, 167, 69, 0.4);
            }
    </style>
</head>
<body class="bg-light">
    <header>
        <nav class="navbar navbar-expand-sm navbar-dark bg-dark border-bottom box-shadow mb-4 py-3">
            <div class="container">
                <a class="navbar-brand fw-bold text-warning fs-4" href="@Url.Action("Index", "Home")">
                    📦 SaleManager Pro
                </a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1 ms-3">
                        <li class="nav-item">
                            <a class="nav-link text-light" href="@Url.Action("Index", "Home")">Dashboard</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-light" href="@Url.Action("Index", "Items")">Sản Phẩm</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-light" href="@Url.Action("Index", "Agents")">Đại Lý</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-light" href="@Url.Action("Index", "Filter")">Báo Cáo</a>
                        </li>
                    </ul>

                    <ul class="navbar-nav align-items-center">
                        <li class="nav-item me-3">
                            <a class="nav-link btn btn-success text-white px-4 py-2 fw-bold btn-order" href="@Url.Action("Create", "Order")">
                                + Tạo Đơn Hàng Mới
                            </a>
                        </li>
                        <li class="nav-item border-start border-secondary ps-3">
                            <a href="@Url.Action("Logout", "Login")" class="btn btn-danger">
                                Đăng Xuất
                            </a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted bg-white mt-5">
        <div class="container py-3">
            &copy; 2026 - Phát triển bởi bạn
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    @RenderSection("scripts", required: false)
</body>
</html>